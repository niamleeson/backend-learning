{
  "title": "JavaScript Backend Developer Path",
  "phases": [
    {
      "id": "phase-1",
      "title": "Intermediate JavaScript & TypeScript",
      "subtitle": "Write JavaScript like a professional, not a student",
      "weeks": "4-6 weeks",
      "description": "Level up with TypeScript, testing, deep async patterns, functional programming, and performance optimization — the skills that separate junior from senior JS developers.",
      "modules": [
        {
          "id": "1.1",
          "title": "TypeScript Fundamentals",
          "lessons": [
            {"id": "1.1.1", "title": "Type Annotations and Basic Types", "type": "lesson", "est_hours": 2},
            {"id": "1.1.2", "title": "Interfaces vs Types: When to Use Each", "type": "lesson", "est_hours": 2},
            {"id": "1.1.3", "title": "Generics: Writing Reusable, Type-Safe Code", "type": "lesson", "est_hours": 3},
            {"id": "1.1.4", "title": "Utility Types: Partial, Required, Pick, Omit, Record", "type": "lesson", "est_hours": 2},
            {"id": "1.1.5", "title": "Conditional Types and Infer", "type": "lesson", "est_hours": 3},
            {"id": "1.1.6", "title": "Strict Mode and tsconfig Best Practices", "type": "lesson", "est_hours": 2},
            {"id": "1.1.7", "title": "Declaration Files and Working with JavaScript Libraries", "type": "lesson", "est_hours": 2}
          ]
        },
        {
          "id": "1.2",
          "title": "Testing",
          "lessons": [
            {"id": "1.2.1", "title": "Jest: Setup, Test Suites, and Assertions", "type": "lesson", "est_hours": 2},
            {"id": "1.2.2", "title": "Vitest: Faster Testing for Modern Projects", "type": "lesson", "est_hours": 2},
            {"id": "1.2.3", "title": "Mocking: jest.fn(), jest.spyOn(), and Module Mocks", "type": "lesson", "est_hours": 3},
            {"id": "1.2.4", "title": "Test Coverage and Testing Best Practices", "type": "lesson", "est_hours": 2},
            {"id": "1.2.5", "title": "Integration Testing and Test Architecture", "type": "lesson", "est_hours": 3}
          ]
        },
        {
          "id": "1.3",
          "title": "Async Patterns",
          "lessons": [
            {"id": "1.3.1", "title": "Promises Deep Dive: Chaining, All, Race, AllSettled", "type": "lesson", "est_hours": 3},
            {"id": "1.3.2", "title": "async/await: Error Handling and Edge Cases", "type": "lesson", "est_hours": 2},
            {"id": "1.3.3", "title": "EventEmitter: Pub/Sub Patterns in Node.js", "type": "lesson", "est_hours": 2},
            {"id": "1.3.4", "title": "Node.js Streams: Readable, Writable, Transform", "type": "lesson", "est_hours": 3},
            {"id": "1.3.5", "title": "Async Iteration and for-await-of", "type": "lesson", "est_hours": 2}
          ]
        },
        {
          "id": "1.4",
          "title": "Functional Patterns",
          "lessons": [
            {"id": "1.4.1", "title": "map, filter, reduce: Deep Dive and Performance", "type": "lesson", "est_hours": 2},
            {"id": "1.4.2", "title": "Immutability: Object.freeze, Spread, and Structural Sharing", "type": "lesson", "est_hours": 2},
            {"id": "1.4.3", "title": "Currying, Partial Application, and Function Composition", "type": "lesson", "est_hours": 3},
            {"id": "1.4.4", "title": "Pure Functions, Side Effects, and Referential Transparency", "type": "lesson", "est_hours": 2}
          ]
        },
        {
          "id": "1.5",
          "title": "Performance",
          "lessons": [
            {"id": "1.5.1", "title": "Profiling Node.js: --inspect, Chrome DevTools, clinic.js", "type": "lesson", "est_hours": 3},
            {"id": "1.5.2", "title": "Memory Leaks: Detection and Common Patterns", "type": "lesson", "est_hours": 3},
            {"id": "1.5.3", "title": "V8 Internals: JIT Compilation, Hidden Classes, and Deoptimization", "type": "lesson", "est_hours": 3}
          ]
        }
      ]
    },
    {
      "id": "phase-2",
      "title": "Databases",
      "subtitle": "Every backend app lives or dies by its data layer",
      "weeks": "5-7 weeks",
      "description": "Master SQL, PostgreSQL, database design, Prisma and Drizzle ORMs, Knex.js query building, Redis caching with ioredis, and MongoDB with Mongoose.",
      "modules": [
        {
          "id": "2.1",
          "title": "SQL Fundamentals",
          "lessons": [
            {"id": "2.1.1", "title": "SELECT, WHERE, and Basic Queries", "type": "lesson", "est_hours": 2},
            {"id": "2.1.2", "title": "JOINs: INNER, LEFT, RIGHT, FULL, CROSS", "type": "lesson", "est_hours": 3},
            {"id": "2.1.3", "title": "Aggregations: GROUP BY, HAVING, COUNT, SUM, AVG", "type": "lesson", "est_hours": 2},
            {"id": "2.1.4", "title": "Subqueries and Correlated Subqueries", "type": "lesson", "est_hours": 3},
            {"id": "2.1.5", "title": "Window Functions: ROW_NUMBER, RANK, LAG, LEAD", "type": "lesson", "est_hours": 3},
            {"id": "2.1.6", "title": "Common Table Expressions (CTEs)", "type": "lesson", "est_hours": 2}
          ]
        },
        {
          "id": "2.2",
          "title": "PostgreSQL Deep Dive",
          "lessons": [
            {"id": "2.2.1", "title": "PostgreSQL Data Types and Type System", "type": "lesson", "est_hours": 2},
            {"id": "2.2.2", "title": "Indexes: B-tree, Hash, GIN, GiST, BRIN", "type": "lesson", "est_hours": 3},
            {"id": "2.2.3", "title": "EXPLAIN ANALYZE and Query Optimization", "type": "lesson", "est_hours": 3},
            {"id": "2.2.4", "title": "JSONB: Storing and Querying Semi-Structured Data", "type": "lesson", "est_hours": 2},
            {"id": "2.2.5", "title": "Full-Text Search in PostgreSQL", "type": "lesson", "est_hours": 2}
          ]
        },
        {
          "id": "2.3",
          "title": "Database Design",
          "lessons": [
            {"id": "2.3.1", "title": "Normalization: 1NF through 3NF and Beyond", "type": "lesson", "est_hours": 3},
            {"id": "2.3.2", "title": "Entity-Relationship Diagrams and Schema Design", "type": "lesson", "est_hours": 2},
            {"id": "2.3.3", "title": "Constraints: PRIMARY KEY, FOREIGN KEY, UNIQUE, CHECK", "type": "lesson", "est_hours": 2},
            {"id": "2.3.4", "title": "Triggers, Views, and Stored Procedures", "type": "lesson", "est_hours": 2}
          ]
        },
        {
          "id": "2.4",
          "title": "Knex.js Query Builder",
          "lessons": [
            {"id": "2.4.1", "title": "Knex Setup, Configuration, and Connection Pooling", "type": "lesson", "est_hours": 2},
            {"id": "2.4.2", "title": "Query Building: select, insert, update, delete", "type": "lesson", "est_hours": 2},
            {"id": "2.4.3", "title": "Transactions and Raw Queries", "type": "lesson", "est_hours": 2},
            {"id": "2.4.4", "title": "Knex Migrations and Seed Files", "type": "lesson", "est_hours": 2}
          ]
        },
        {
          "id": "2.5",
          "title": "Prisma ORM",
          "lessons": [
            {"id": "2.5.1", "title": "Prisma Schema: Models, Relations, and Data Types", "type": "lesson", "est_hours": 3},
            {"id": "2.5.2", "title": "Prisma Client: CRUD, Filtering, and Sorting", "type": "lesson", "est_hours": 2},
            {"id": "2.5.3", "title": "Relations: One-to-Many, Many-to-Many, and Nested Writes", "type": "lesson", "est_hours": 3},
            {"id": "2.5.4", "title": "Prisma Migrate: Creating and Running Migrations", "type": "lesson", "est_hours": 2},
            {"id": "2.5.5", "title": "Prisma Studio and Debugging Queries", "type": "lesson", "est_hours": 1}
          ]
        },
        {
          "id": "2.6",
          "title": "Drizzle ORM",
          "lessons": [
            {"id": "2.6.1", "title": "Drizzle Setup and Schema Definition", "type": "lesson", "est_hours": 2},
            {"id": "2.6.2", "title": "Queries: Type-Safe SQL with Drizzle", "type": "lesson", "est_hours": 2},
            {"id": "2.6.3", "title": "Drizzle Migrations and Drizzle Kit", "type": "lesson", "est_hours": 2}
          ]
        },
        {
          "id": "2.7",
          "title": "Redis with ioredis",
          "lessons": [
            {"id": "2.7.1", "title": "Redis Data Structures: Strings, Lists, Hashes, Sets, Sorted Sets", "type": "lesson", "est_hours": 3},
            {"id": "2.7.2", "title": "Caching Patterns: Cache-Aside, Write-Through, TTL", "type": "lesson", "est_hours": 3},
            {"id": "2.7.3", "title": "Pub/Sub and Lua Scripting", "type": "lesson", "est_hours": 2},
            {"id": "2.7.4", "title": "ioredis: Async Client, Pipelining, and Cluster Mode", "type": "lesson", "est_hours": 2}
          ]
        },
        {
          "id": "2.8",
          "title": "MongoDB with Mongoose",
          "lessons": [
            {"id": "2.8.1", "title": "Document Model and CRUD Operations", "type": "lesson", "est_hours": 2},
            {"id": "2.8.2", "title": "Aggregation Pipeline", "type": "lesson", "est_hours": 3},
            {"id": "2.8.3", "title": "Mongoose: Schemas, Models, Validation, and Middleware", "type": "lesson", "est_hours": 3}
          ]
        }
      ]
    },
    {
      "id": "phase-3",
      "title": "Web Frameworks — Express.js",
      "subtitle": "Build your first production-grade Node.js API from scratch",
      "weeks": "4-5 weeks",
      "description": "Learn Express.js from fundamentals through middleware, REST API design, authentication with Passport.js and JWT, Prisma integration, and building a complete project.",
      "modules": [
        {
          "id": "3.1",
          "title": "Express Fundamentals",
          "lessons": [
            {"id": "3.1.1", "title": "Express App Setup and Project Structure", "type": "lesson", "est_hours": 2},
            {"id": "3.1.2", "title": "Routing: Methods, Parameters, and Query Strings", "type": "lesson", "est_hours": 2},
            {"id": "3.1.3", "title": "Request and Response Objects", "type": "lesson", "est_hours": 2},
            {"id": "3.1.4", "title": "Express Router: Modular Route Organization", "type": "lesson", "est_hours": 2},
            {"id": "3.1.5", "title": "Configuration Management and Environment Variables", "type": "lesson", "est_hours": 2}
          ]
        },
        {
          "id": "3.2",
          "title": "Middleware",
          "lessons": [
            {"id": "3.2.1", "title": "Middleware Anatomy: req, res, next", "type": "lesson", "est_hours": 2},
            {"id": "3.2.2", "title": "Built-in Middleware: express.json, express.static", "type": "lesson", "est_hours": 1},
            {"id": "3.2.3", "title": "Third-Party Middleware: cors, helmet, morgan, compression", "type": "lesson", "est_hours": 2},
            {"id": "3.2.4", "title": "Writing Custom Middleware", "type": "lesson", "est_hours": 2},
            {"id": "3.2.5", "title": "Error Handling Middleware and Global Error Handler", "type": "lesson", "est_hours": 3}
          ]
        },
        {
          "id": "3.3",
          "title": "REST API Design",
          "lessons": [
            {"id": "3.3.1", "title": "REST Principles and Resource Design", "type": "lesson", "est_hours": 2},
            {"id": "3.3.2", "title": "HTTP Methods, Status Codes, and Content Negotiation", "type": "lesson", "est_hours": 2},
            {"id": "3.3.3", "title": "Standardized Error Responses and Validation", "type": "lesson", "est_hours": 2}
          ]
        },
        {
          "id": "3.4",
          "title": "Authentication",
          "lessons": [
            {"id": "3.4.1", "title": "Passport.js: Strategies and Session Management", "type": "lesson", "est_hours": 3},
            {"id": "3.4.2", "title": "JWT Authentication: Tokens, Refresh, and Revocation", "type": "lesson", "est_hours": 3},
            {"id": "3.4.3", "title": "OAuth2 Basics with Passport.js", "type": "lesson", "est_hours": 3}
          ]
        },
        {
          "id": "3.5",
          "title": "Database Integration",
          "lessons": [
            {"id": "3.5.1", "title": "Integrating Prisma with Express", "type": "lesson", "est_hours": 2},
            {"id": "3.5.2", "title": "Repository Pattern in Express", "type": "lesson", "est_hours": 3},
            {"id": "3.5.3", "title": "Connection Pooling and Performance", "type": "lesson", "est_hours": 2}
          ]
        },
        {
          "id": "3.6",
          "title": "Project: Full REST API",
          "lessons": [
            {"id": "3.6.1", "title": "Project Setup: Blog API with Auth and CRUD", "type": "project", "est_hours": 4},
            {"id": "3.6.2", "title": "Pagination, Filtering, and Search", "type": "project", "est_hours": 3},
            {"id": "3.6.3", "title": "Testing the API and Deployment Prep", "type": "project", "est_hours": 3}
          ]
        }
      ]
    },
    {
      "id": "phase-4",
      "title": "Web Frameworks — NestJS",
      "subtitle": "The opinionated, enterprise-grade Node.js framework",
      "weeks": "4-5 weeks",
      "description": "Master NestJS's module system, dependency injection, decorators, guards, pipes, interceptors, auth, database integration, WebSockets, and build a production-ready API.",
      "modules": [
        {
          "id": "4.1",
          "title": "NestJS Fundamentals",
          "lessons": [
            {"id": "4.1.1", "title": "NestJS Architecture and CLI Setup", "type": "lesson", "est_hours": 2},
            {"id": "4.1.2", "title": "Modules: Feature Modules and Module Graph", "type": "lesson", "est_hours": 2},
            {"id": "4.1.3", "title": "Controllers: Routes, Parameters, and DTOs", "type": "lesson", "est_hours": 2},
            {"id": "4.1.4", "title": "Providers and Services: Dependency Injection Basics", "type": "lesson", "est_hours": 3},
            {"id": "4.1.5", "title": "Configuration: ConfigModule and Environment Variables", "type": "lesson", "est_hours": 2}
          ]
        },
        {
          "id": "4.2",
          "title": "Dependency Injection",
          "lessons": [
            {"id": "4.2.1", "title": "NestJS DI Container: Providers, Scopes, and Tokens", "type": "lesson", "est_hours": 3},
            {"id": "4.2.2", "title": "Custom Providers: useValue, useFactory, useExisting", "type": "lesson", "est_hours": 2},
            {"id": "4.2.3", "title": "Circular Dependencies and forwardRef", "type": "lesson", "est_hours": 2}
          ]
        },
        {
          "id": "4.3",
          "title": "Guards, Pipes & Interceptors",
          "lessons": [
            {"id": "4.3.1", "title": "Guards: Authentication and Authorization", "type": "lesson", "est_hours": 3},
            {"id": "4.3.2", "title": "Pipes: Validation and Transformation with class-validator", "type": "lesson", "est_hours": 3},
            {"id": "4.3.3", "title": "Interceptors: Logging, Caching, and Response Transformation", "type": "lesson", "est_hours": 3},
            {"id": "4.3.4", "title": "Exception Filters: Custom Error Handling", "type": "lesson", "est_hours": 2}
          ]
        },
        {
          "id": "4.4",
          "title": "Authentication",
          "lessons": [
            {"id": "4.4.1", "title": "@nestjs/passport: Strategies and Guards", "type": "lesson", "est_hours": 3},
            {"id": "4.4.2", "title": "JWT Strategy and Auth Module", "type": "lesson", "est_hours": 3},
            {"id": "4.4.3", "title": "Refresh Tokens and Token Revocation", "type": "lesson", "est_hours": 2}
          ]
        },
        {
          "id": "4.5",
          "title": "Database Integration",
          "lessons": [
            {"id": "4.5.1", "title": "TypeORM with NestJS: Entities and Repositories", "type": "lesson", "est_hours": 3},
            {"id": "4.5.2", "title": "Prisma with NestJS: PrismaService and Module", "type": "lesson", "est_hours": 2},
            {"id": "4.5.3", "title": "Database Transactions in NestJS", "type": "lesson", "est_hours": 2}
          ]
        },
        {
          "id": "4.6",
          "title": "WebSockets",
          "lessons": [
            {"id": "4.6.1", "title": "Gateways: @WebSocketGateway and Events", "type": "lesson", "est_hours": 2},
            {"id": "4.6.2", "title": "Building a Real-Time Chat Application", "type": "project", "est_hours": 4},
            {"id": "4.6.3", "title": "Room-Based Messaging and Presence", "type": "lesson", "est_hours": 2}
          ]
        },
        {
          "id": "4.7",
          "title": "Project: Production API",
          "lessons": [
            {"id": "4.7.1", "title": "Project: Full CRUD API with Auth and Pagination", "type": "project", "est_hours": 4},
            {"id": "4.7.2", "title": "File Uploads, Filtering, and Advanced Features", "type": "project", "est_hours": 3},
            {"id": "4.7.3", "title": "Testing, Documentation, and Production Config", "type": "project", "est_hours": 3}
          ]
        }
      ]
    },
    {
