{
  "title": "Python Backend Developer Path",
  "phases": [
    {
      "id": "phase-1",
      "title": "Python Fundamentals",
      "subtitle": "Master the language before building with it",
      "weeks": "6-8 weeks",
      "description": "Build a rock-solid foundation in Python — data types, functions, OOP, data structures, error handling, and the tools every Python developer uses daily.",
      "modules": [
        {
          "id": "1.1",
          "title": "Python Core",
          "lessons": [
            {"id": "1.1.1", "title": "Python Installation & Environment Setup", "type": "lesson", "est_hours": 1},
            {"id": "1.1.2", "title": "Variables, Constants, and Naming Conventions", "type": "lesson", "est_hours": 2},
            {"id": "1.1.3", "title": "Numeric Types: int, float, complex", "type": "lesson", "est_hours": 2},
            {"id": "1.1.4", "title": "Strings and String Methods", "type": "lesson", "est_hours": 3},
            {"id": "1.1.5", "title": "Boolean Logic and Truthiness", "type": "lesson", "est_hours": 2},
            {"id": "1.1.6", "title": "Operators: Arithmetic, Comparison, Logical, Bitwise", "type": "lesson", "est_hours": 2},
            {"id": "1.1.7", "title": "Control Flow: if, elif, else", "type": "lesson", "est_hours": 2},
            {"id": "1.1.8", "title": "Loops: for and while", "type": "lesson", "est_hours": 3},
            {"id": "1.1.9", "title": "Comprehensions: List, Dict, Set", "type": "lesson", "est_hours": 3}
          ]
        },
        {
          "id": "1.2",
          "title": "Functions & Scope",
          "lessons": [
            {"id": "1.2.1", "title": "Defining Functions and Return Values", "type": "lesson", "est_hours": 2},
            {"id": "1.2.2", "title": "Arguments: Positional, Keyword, Default", "type": "lesson", "est_hours": 2},
            {"id": "1.2.3", "title": "*args and **kwargs", "type": "lesson", "est_hours": 2},
            {"id": "1.2.4", "title": "Scope and the LEGB Rule", "type": "lesson", "est_hours": 2},
            {"id": "1.2.5", "title": "Closures and Nested Functions", "type": "lesson", "est_hours": 3},
            {"id": "1.2.6", "title": "Decorators: Building and Stacking", "type": "lesson", "est_hours": 3},
            {"id": "1.2.7", "title": "Lambda Functions and First-Class Functions", "type": "lesson", "est_hours": 2}
          ]
        },
        {
          "id": "1.3",
          "title": "Object-Oriented Programming",
          "lessons": [
            {"id": "1.3.1", "title": "Classes and Objects", "type": "lesson", "est_hours": 3},
            {"id": "1.3.2", "title": "Instance, Class, and Static Methods", "type": "lesson", "est_hours": 2},
            {"id": "1.3.3", "title": "Properties and Encapsulation", "type": "lesson", "est_hours": 2},
            {"id": "1.3.4", "title": "Inheritance and Method Resolution Order", "type": "lesson", "est_hours": 3},
            {"id": "1.3.5", "title": "Composition Over Inheritance", "type": "lesson", "est_hours": 2},
            {"id": "1.3.6", "title": "Dunder Methods: __str__, __repr__, __eq__, __hash__", "type": "lesson", "est_hours": 3},
            {"id": "1.3.7", "title": "Abstract Base Classes (ABC)", "type": "lesson", "est_hours": 2},
            {"id": "1.3.8", "title": "Dataclasses and Named Tuples", "type": "lesson", "est_hours": 2}
          ]
        },
        {
          "id": "1.4",
          "title": "Data Structures",
          "lessons": [
            {"id": "1.4.1", "title": "Lists: Operations, Slicing, and Performance", "type": "lesson", "est_hours": 2},
            {"id": "1.4.2", "title": "Dictionaries: Internals and Patterns", "type": "lesson", "est_hours": 3},
            {"id": "1.4.3", "title": "Sets and Frozensets", "type": "lesson", "est_hours": 2},
            {"id": "1.4.4", "title": "Tuples and Immutability", "type": "lesson", "est_hours": 1},
            {"id": "1.4.5", "title": "collections Module: Counter, defaultdict, OrderedDict, deque", "type": "lesson", "est_hours": 3},
            {"id": "1.4.6", "title": "heapq and bisect: Priority Queues and Sorted Insertion", "type": "lesson", "est_hours": 2}
          ]
        },
        {
          "id": "1.5",
          "title": "Error Handling",
          "lessons": [
            {"id": "1.5.1", "title": "Exceptions: try, except, finally, else", "type": "lesson", "est_hours": 2},
            {"id": "1.5.2", "title": "Built-in Exception Hierarchy", "type": "lesson", "est_hours": 2},
            {"id": "1.5.3", "title": "Custom Exceptions", "type": "lesson", "est_hours": 2},
            {"id": "1.5.4", "title": "Context Managers and the with Statement", "type": "lesson", "est_hours": 3},
            {"id": "1.5.5", "title": "Logging: Basics to Production Setup", "type": "lesson", "est_hours": 3}
          ]
        },
        {
          "id": "1.6",
          "title": "Modules & Packages",
          "lessons": [
            {"id": "1.6.1", "title": "Import System: Modules, Packages, __init__.py", "type": "lesson", "est_hours": 2},
            {"id": "1.6.2", "title": "Virtual Environments: venv, pip, pip-tools", "type": "lesson", "est_hours": 2},
            {"id": "1.6.3", "title": "Project Layout and Packaging with pyproject.toml", "type": "lesson", "est_hours": 2},
            {"id": "1.6.4", "title": "Dependency Management: pip, Poetry, uv", "type": "lesson", "est_hours": 2}
          ]
        },
        {
          "id": "1.7",
          "title": "File I/O & Serialization",
          "lessons": [
            {"id": "1.7.1", "title": "Reading and Writing Text Files", "type": "lesson", "est_hours": 2},
            {"id": "1.7.2", "title": "Working with JSON", "type": "lesson", "est_hours": 2},
            {"id": "1.7.3", "title": "CSV and Data Files", "type": "lesson", "est_hours": 2},
            {"id": "1.7.4", "title": "pathlib: Modern Path Handling", "type": "lesson", "est_hours": 2},
            {"id": "1.7.5", "title": "Pickle, shelve, and Binary Formats", "type": "lesson", "est_hours": 2}
          ]
        },
        {
          "id": "1.8",
          "title": "Iterators & Generators",
          "lessons": [
            {"id": "1.8.1", "title": "The Iterator Protocol: __iter__ and __next__", "type": "lesson", "est_hours": 2},
            {"id": "1.8.2", "title": "Generator Functions and yield", "type": "lesson", "est_hours": 3},
            {"id": "1.8.3", "title": "Generator Expressions", "type": "lesson", "est_hours": 2},
            {"id": "1.8.4", "title": "itertools: Infinite Iterators, Combinatorics, and Recipes", "type": "lesson", "est_hours": 3}
          ]
        }
      ]
    },
    {
      "id": "phase-2",
      "title": "Intermediate Python",
      "subtitle": "Write Python like a professional, not a student",
      "weeks": "4-6 weeks",
      "description": "Level up with type hints, testing, concurrency, async programming, functional patterns, metaprogramming, and performance optimization.",
      "modules": [
        {
          "id": "2.1",
          "title": "Type Hints & Mypy",
          "lessons": [
            {"id": "2.1.1", "title": "Type Annotations: Basics and Benefits", "type": "lesson", "est_hours": 2},
            {"id": "2.1.2", "title": "Generics, Union, Optional, and TypeVar", "type": "lesson", "est_hours": 3},
            {"id": "2.1.3", "title": "Protocol and Structural Subtyping", "type": "lesson", "est_hours": 2},
            {"id": "2.1.4", "title": "Mypy Configuration and CI Integration", "type": "lesson", "est_hours": 2}
          ]
        },
        {
          "id": "2.2",
          "title": "Testing",
          "lessons": [
            {"id": "2.2.1", "title": "unittest: Test Cases, Assertions, and Runners", "type": "lesson", "est_hours": 2},
            {"id": "2.2.2", "title": "pytest: Fixtures, Markers, and Parametrize", "type": "lesson", "est_hours": 3},
            {"id": "2.2.3", "title": "Mocking: unittest.mock, patch, MagicMock", "type": "lesson", "est_hours": 3},
            {"id": "2.2.4", "title": "Test Coverage and Testing Best Practices", "type": "lesson", "est_hours": 2},
            {"id": "2.2.5", "title": "Integration Testing and Test Architecture", "type": "lesson", "est_hours": 3}
          ]
        },
        {
          "id": "2.3",
          "title": "Concurrency Basics",
          "lessons": [
            {"id": "2.3.1", "title": "Threading: Threads, Locks, and the GIL", "type": "lesson", "est_hours": 3},
            {"id": "2.3.2", "title": "Multiprocessing: Processes, Pools, and Shared State", "type": "lesson", "est_hours": 3},
            {"id": "2.3.3", "title": "concurrent.futures: ThreadPoolExecutor and ProcessPoolExecutor", "type": "lesson", "est_hours": 2},
            {"id": "2.3.4", "title": "When to Use Threads vs Processes vs Async", "type": "lesson", "est_hours": 2}
          ]
        },
        {
          "id": "2.4",
          "title": "Async/Await",
          "lessons": [
            {"id": "2.4.1", "title": "The Event Loop and Coroutines", "type": "lesson", "est_hours": 3},
            {"id": "2.4.2", "title": "asyncio: Tasks, gather, and wait", "type": "lesson", "est_hours": 3},
            {"id": "2.4.3", "title": "Async I/O: aiohttp, aiofiles", "type": "lesson", "est_hours": 2},
            {"id": "2.4.4", "title": "Async Patterns: Semaphores, Queues, and Error Handling", "type": "lesson", "est_hours": 3}
          ]
        },
        {
          "id": "2.5",
          "title": "Functional Patterns",
          "lessons": [
            {"id": "2.5.1", "title": "map, filter, reduce and When to Use Them", "type": "lesson", "est_hours": 2},
            {"id": "2.5.2", "title": "functools: partial, lru_cache, wraps, reduce", "type": "lesson", "est_hours": 2},
            {"id": "2.5.3", "title": "Immutability Patterns and Pure Functions", "type": "lesson", "est_hours": 2}
          ]
        },
        {
          "id": "2.6",
          "title": "Metaprogramming",
          "lessons": [
            {"id": "2.6.1", "title": "Metaclasses: type, __new__, and Custom Metaclasses", "type": "lesson", "est_hours": 3},
            {"id": "2.6.2", "title": "Descriptors: __get__, __set__, __delete__", "type": "lesson", "est_hours": 3},
            {"id": "2.6.3", "title": "__init_subclass__ and Dynamic Class Creation", "type": "lesson", "est_hours": 2}
          ]
        },
        {
          "id": "2.7",
          "title": "Performance",
          "lessons": [
            {"id": "2.7.1", "title": "Profiling: cProfile, line_profiler, py-spy", "type": "lesson", "est_hours": 3},
            {"id": "2.7.2", "title": "Memory Profiling: tracemalloc and memory_profiler", "type": "lesson", "est_hours": 2},
            {"id": "2.7.3", "title": "Optimization Patterns: Caching, Lazy Evaluation, Slots", "type": "lesson", "est_hours": 3}
          ]
        }
      ]
    },
    {
      "id": "phase-3",
      "title": "Databases",
      "subtitle": "Every backend app lives or dies by its data layer",
      "weeks": "5-7 weeks",
      "description": "Master SQL, PostgreSQL, database design, SQLAlchemy (Core and ORM), Alembic migrations, Redis caching, and MongoDB for document storage.",
      "modules": [
        {
          "id": "3.1",
          "title": "SQL Fundamentals",
          "lessons": [
            {"id": "3.1.1", "title": "SELECT, WHERE, and Basic Queries", "type": "lesson", "est_hours": 2},
            {"id": "3.1.2", "title": "JOINs: INNER, LEFT, RIGHT, FULL, CROSS", "type": "lesson", "est_hours": 3},
            {"id": "3.1.3", "title": "Aggregations: GROUP BY, HAVING, COUNT, SUM, AVG", "type": "lesson", "est_hours": 2},
            {"id": "3.1.4", "title": "Subqueries and Correlated Subqueries", "type": "lesson", "est_hours": 3},
            {"id": "3.1.5", "title": "Window Functions: ROW_NUMBER, RANK, LAG, LEAD", "type": "lesson", "est_hours": 3},
            {"id": "3.1.6", "title": "Common Table Expressions (CTEs)", "type": "lesson", "est_hours": 2}
          ]
        },
        {
          "id": "3.2",
          "title": "PostgreSQL Deep Dive",
          "lessons": [
            {"id": "3.2.1", "title": "PostgreSQL Data Types and Type System", "type": "lesson", "est_hours": 2},
            {"id": "3.2.2", "title": "Indexes: B-tree, Hash, GIN, GiST, BRIN", "type": "lesson", "est_hours": 3},
            {"id": "3.2.3", "title": "EXPLAIN ANALYZE and Query Optimization", "type": "lesson", "est_hours": 3},
            {"id": "3.2.4", "title": "JSONB: Storing and Querying Semi-Structured Data", "type": "lesson", "est_hours": 2},
            {"id": "3.2.5", "title": "Full-Text Search in PostgreSQL", "type": "lesson", "est_hours": 2}
          ]
        },
        {
          "id": "3.3",
          "title": "Database Design",
          "lessons": [
            {"id": "3.3.1", "title": "Normalization: 1NF through 3NF and Beyond", "type": "lesson", "est_hours": 3},
            {"id": "3.3.2", "title": "Entity-Relationship Diagrams and Schema Design", "type": "lesson", "est_hours": 2},
            {"id": "3.3.3", "title": "Constraints: PRIMARY KEY, FOREIGN KEY, UNIQUE, CHECK", "type": "lesson", "est_hours": 2},
            {"id": "3.3.4", "title": "Triggers, Views, and Stored Procedures", "type": "lesson", "est_hours": 2}
          ]
        },
        {
          "id": "3.4",
          "title": "SQLAlchemy Core",
          "lessons": [
            {"id": "3.4.1", "title": "Engine, Connection, and Execution", "type": "lesson", "est_hours": 2},
            {"id": "3.4.2", "title": "MetaData, Table, and Column Definitions", "type": "lesson", "est_hours": 2},
            {"id": "3.4.3", "title": "SQL Expression Language: select, insert, update, delete", "type": "lesson", "est_hours": 3},
            {"id": "3.4.4", "title": "Transactions and Connection Pooling", "type": "lesson", "est_hours": 2}
          ]
        },
        {
          "id": "3.5",
          "title": "SQLAlchemy ORM",
          "lessons": [
            {"id": "3.5.1", "title": "Declarative Models and Mapped Columns", "type": "lesson", "est_hours": 3},
            {"id": "3.5.2", "title": "Sessions: add, commit, rollback, flush", "type": "lesson", "est_hours": 2},
            {"id": "3.5.3", "title": "Relationships: One-to-Many, Many-to-Many, Back Populates", "type": "lesson", "est_hours": 3},
            {"id": "3.5.4", "title": "Eager vs Lazy Loading: joinedload, selectinload, subqueryload", "type": "lesson", "est_hours": 3},
            {"id": "3.5.5", "title": "Advanced Queries: Hybrid Properties, Query API, and Filtering", "type": "lesson", "est_hours": 2}
          ]
        },
        {
          "id": "3.6",
          "title": "Alembic Migrations",
          "lessons": [
            {"id": "3.6.1", "title": "Alembic Setup and Configuration", "type": "lesson", "est_hours": 2},
            {"id": "3.6.2", "title": "Creating and Running Migrations", "type": "lesson", "est_hours": 2},
            {"id": "3.6.3", "title": "Autogenerate, Branching, and Migration Strategies", "type": "lesson", "est_hours": 3}
          ]
        },
        {
          "id": "3.7",
          "title": "Redis",
          "lessons": [
            {"id": "3.7.1", "title": "Redis Data Structures: Strings, Lists, Hashes, Sets, Sorted Sets", "type": "lesson", "est_hours": 3},
            {"id": "3.7.2", "title": "Caching Patterns: Cache-Aside, Write-Through, TTL", "type": "lesson", "est_hours": 3},
            {"id": "3.7.3", "title": "Pub/Sub and Lua Scripting", "type": "lesson", "est_hours": 2},
            {"id": "3.7.4", "title": "Redis in Python: redis-py and Async Redis", "type": "lesson", "est_hours": 2}
          ]
        },
        {
          "id": "3.8",
          "title": "MongoDB (NoSQL)",
          "lessons": [
            {"id": "3.8.1", "title": "Document Model and CRUD Operations", "type": "lesson", "est_hours": 2},
            {"id": "3.8.2", "title": "Aggregation Pipeline", "type": "lesson", "est_hours": 3},
            {"id": "3.8.3", "title": "Indexes, Schema Design, and pymongo", "type": "lesson", "est_hours": 2}
          ]
        }
      ]
    },
    {
