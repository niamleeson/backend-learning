        },
        {
          "id": "5.3",
          "title": "tRPC",
          "lessons": [
            {"id": "5.3.1", "title": "tRPC Fundamentals: Routers, Procedures, and Context", "type": "lesson", "est_hours": 2},
            {"id": "5.3.2", "title": "Input Validation with Zod and End-to-End Type Safety", "type": "lesson", "est_hours": 2},
            {"id": "5.3.3", "title": "tRPC with Express and NestJS", "type": "lesson", "est_hours": 2}
          ]
        },
        {
          "id": "5.4",
          "title": "gRPC",
          "lessons": [
            {"id": "5.4.1", "title": "Protocol Buffers and Service Definitions", "type": "lesson", "est_hours": 3},
